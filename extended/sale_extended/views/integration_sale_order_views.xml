<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="integration_sale_order_view_form" model="ir.ui.view">
        <field name="name">integration.sale.order.view.form</field>
        <field name="model">integration.sale.order</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="external_order_id" />
                            <field name="sale_id" />
                        </group>
                        <group>
                            <field name="processed_at" />
                        </group>
                    </group>
                    <group>
                        <field name="payload" widget="json_widget" />
                    </group>
                    <notebook>
                        <page name="logs" string="Logs">
                            <field name="log_ids">
                                <list decoration-success="level == 'info'" decoration-warning="level == 'warning'" decoration-danger="level == 'error'">
                                    <field name="level" />            
                                    <field name="message" />            
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="integration_sale_order_view_list" model="ir.ui.view">
        <field name="name">integration.sale.order.view.list</field>
        <field name="model">integration.sale.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="external_order_id" />
                <field name="processed_at" />
                <field name="sale_id" />
                <field name="state" />
            </list> 
        </field>
    </record>

    <record id="integration_sale_order_action" model="ir.actions.act_window">
        <field name="name">Integration Sale Order</field>
        <field name="res_model">integration.sale.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem 
        id="integration_menu_root"
        name="Integration"
        parent="sale.sale_menu_root"
        sequence="45"/>

    <menuitem
        id="integration_sale_order_menu"
        name="Sale Order API"
        action="integration_sale_order_action"
        parent="integration_menu_root"/>
    
</odoo>

